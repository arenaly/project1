PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
# 여러 도메인 허용 시 쉼표로 구분 (Vercel 프로덕션/프리뷰 도메인 등)
# FRONTEND_ORIGINS=https://project-frontend.vercel.app,https://project-frontend-git-main-xxx.vercel.app
# true면 https://*.vercel.app 도메인을 추가 허용
ALLOW_VERCEL_APP_ORIGINS=false

# AI API (OpenAI 호환)
# OPENAI_BASE_URL을 지정하지 않으면 https://api.openai.com/v1 사용
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Supabase (선택)
SUPABASE_URL=
SUPABASE_ANON_KEY=
